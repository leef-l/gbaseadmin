{
  "name": "wap-ui",
  "version": "1.0.0",
  "private": true,
  "description": "陪玩平台WAP端",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:tt": "taro build --type tt",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:tt": "npm run build:tt -- --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@nutui/nutui-react-taro": "^2.7.0",
    "@tarojs/cli": "4.x",
    "@tarojs/components": "4.x",
    "@tarojs/helper": "4.x",
    "@tarojs/plugin-framework-react": "4.x",
    "@tarojs/plugin-platform-h5": "4.x",
    "@tarojs/plugin-platform-tt": "4.x",
    "@tarojs/plugin-platform-weapp": "4.x",
    "@tarojs/react": "4.x",
    "@tarojs/runtime": "4.x",
    "@tarojs/shared": "4.x",
    "@tarojs/taro": "4.x",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "core-js-pure"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@tarojs/webpack5-runner": "4.x",
    "@types/react": "^18.3.0",
    "babel-preset-taro": "^4.1.11",
    "sass": "^1.77.0",
    "typescript": "^5.4.0"
  }
}
