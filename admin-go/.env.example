# ─────────────────────────────────────────────────────────────
# GBaseAdmin 环境变量配置示例
# 如果通过 docker/dev/compose.ps1 启动，admin-go/.env 会由 docker/dev/.env 自动覆盖
# 本文件主要用于非 Docker 场景或手动恢复
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# MySQL 配置
# ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=gbaseadmin123
MYSQL_HOST=127.0.0.1
MYSQL_USER=gbaseadmin
MYSQL_PASSWORD=gbaseadmin123
MYSQL_DATABASE=gbaseadmin
MYSQL_PORT=40001

# ─────────────────────────────────────────────
# Redis 配置
# ─────────────────────────────────────────────
REDIS_PASSWORD=gbaseadmin123
REDIS_PORT=40002

# ─────────────────────────────────────────────
# JWT 配置
# ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please

# ─────────────────────────────────────────────
# 服务端口配置
# ─────────────────────────────────────────────
SYSTEM_PORT=40003
UPLOAD_PORT=40004
FRONTEND_PORT=40005
ADMINER_PORT=40006

# ─────────────────────────────────────────────
# 前端运行时配置
# ─────────────────────────────────────────────
VITE_GLOB_API_URL=http://localhost:40003
