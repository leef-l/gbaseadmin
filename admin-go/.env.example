# ─────────────────────────────────────────────────────────────
# GBaseAdmin 环境变量配置示例
# 使用方法：cp .env.example .env，然后根据实际情况修改 .env
# 注意：.env 文件已加入 .gitignore，请勿提交到版本库
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# MySQL 配置
# ─────────────────────────────────────────────
# MySQL root 账号密码（容器初始化时设置）
MYSQL_ROOT_PASSWORD=gbaseadmin123

# 应用使用的 MySQL 账号（建议非 root）
MYSQL_USER=gbaseadmin
MYSQL_PASSWORD=gbaseadmin123

# 数据库名称
MYSQL_DATABASE=gbaseadmin

# MySQL 对外暴露端口（宿主机端口，默认 3306）
MYSQL_PORT=3306

# ─────────────────────────────────────────────
# Redis 配置
# ─────────────────────────────────────────────
# Redis 连接密码
REDIS_PASSWORD=gbaseadmin123

# Redis 对外暴露端口（宿主机端口，默认 6379）
REDIS_PORT=6379

# ─────────────────────────────────────────────
# JWT 配置
# ─────────────────────────────────────────────
# JWT 签名密钥（生产环境请务必更换为随机字符串，建议 64 位以上）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please

# ─────────────────────────────────────────────
# 服务端口配置
# ─────────────────────────────────────────────
# GoFrame 后端服务端口
SYSTEM_PORT=8000

# 前端服务端口（开发模式 Vite devserver / 生产模式 Nginx）
FRONTEND_PORT=5555

# Adminer 数据库管理界面端口（仅开发环境）
ADMINER_PORT=8080

# ─────────────────────────────────────────────
# 前端运行时配置
# ─────────────────────────────────────────────
# 前端请求后端 API 的地址
# 开发环境：http://localhost:8000
# 生产环境：https://your-domain.com（或 nginx 内部转发时填 /api 前缀）
VITE_GLOB_API_URL=http://localhost:8000
