# https://goframe.org/docs/web/server-config-file-template
server:
  address:     ":8001"
  openapiPath: "/api.json"
  swaggerPath: "/swagger"

# https://goframe.org/docs/core/glog-config
logger:
  level : "all"
  stdout: true

# https://goframe.org/docs/core/gdb-config-file
database:
  default:
    link: "mysql:gbaseadmin:gbaseadmin123@tcp(mysql:3306)/gbaseadmin"
    debug: true
    charset: "utf8mb4"

# https://goframe.org/docs/components/nosql-redis-config
redis:
  default:
    address: "redis:6379"
    pass: "gbaseadmin123"
    db: 1

# JWT 配置
jwt:
  secret: "gbaseadmin-secret-key-2026"
  expire: 24  # Token 过期时间（小时）
